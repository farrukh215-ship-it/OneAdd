generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  phone     String    @unique
  email     String?   @unique
  passwordHash String?
  role      UserRole  @default(USER)
  name      String?
  city      String?
  area      String?
  cnicHash  String?   @unique
  verified  Boolean   @default(false)
  banned    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  listings  Listing[]
  sessions  Session[]
  savedAds  SavedAd[]
  contacts  ContactLog[]
  messages  ListingMessage[]
  offers    Offer[]
  pushTokens UserPushToken[]
  notifications Notification[]
  notificationPreference UserNotificationPreference?
  savedSearches SavedSearch[]
  workshopInspectionVerifications InspectionRequest[] @relation("WorkshopVerifier")
  policeInspectionVerifications   InspectionRequest[] @relation("PoliceVerifier")
  adminInspectionReviews          InspectionRequest[] @relation("AdminReviewer")
  inspectionRequests              InspectionRequest[] @relation("InspectionSeller")
  inspectionAuditLogs             InspectionAuditLog[]
}

model Listing {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  title       String
  description String
  price       Int
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  subcategorySlug String?
  subcategoryName String?
  attributes  Json?
  images      String[]
  videos      String[]      @default([])
  condition   Condition     @default(USED)
  storeType   StoreType?
  isStore     Boolean       @default(false)
  city        String
  area        String?
  lat         Float?
  lng         Float?
  status      ListingStatus @default(ACTIVE)
  inspectionStatus ListingInspectionStatus @default(NONE)
  isInspectionApproved Boolean @default(false)
  inspectionApprovedAt DateTime?
  inspectionBadgeLabel String? @default("TGMG Inspected")
  isFeatured  Boolean       @default(false)
  views       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  savedBy     SavedAd[]
  contacts    ContactLog[]
  thread      ListingThread?
  offers      Offer[]
  viewLogs    ListingViewLog[]
  inspectionRequests InspectionRequest[]

  @@index([city])
  @@index([storeType])
  @@index([isStore])
  @@index([isStore, storeType])
  @@index([lat, lng])
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  icon     String
  order    Int       @default(0)
  listings Listing[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SavedAd {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model ContactLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())
}

model ListingThread {
  id        String          @id @default(cuid())
  listingId String          @unique
  listing   Listing         @relation(fields: [listingId], references: [id])
  messages  ListingMessage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ListingMessage {
  id          String        @id @default(cuid())
  threadId     String
  thread       ListingThread @relation(fields: [threadId], references: [id])
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  message      String
  offerAmount  Int?
  createdAt    DateTime      @default(now())

  @@index([threadId, createdAt])
}

model Offer {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Int
  createdAt DateTime @default(now())

  @@index([listingId, amount])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  title     String
  body      String
  href      String
  type      NotificationType
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model ListingViewLog {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@index([listingId, createdAt])
}

model UserPushToken {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  token      String       @unique
  platform   PushPlatform @default(ANDROID)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  lastSeenAt DateTime     @default(now())

  @@index([userId, platform])
}

model UserNotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  contacts        Boolean  @default(true)
  savedUpdates    Boolean  @default(true)
  newListings     Boolean  @default(true)
  pushEnabled     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SavedSearch {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  label         String?
  q             String?
  category      String?
  city          String?
  condition     Condition?
  minPrice      Int?
  maxPrice      Int?
  lat           Float?
  lng           Float?
  radiusKm      Int?
  alertsEnabled Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, updatedAt])
  @@index([userId, alertsEnabled])
}

model WorkshopPartner {
  id        String   @id @default(cuid())
  name      String
  city      String
  address   String
  contact   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  inspectionRequests InspectionRequest[]

  @@index([city, active])
}

model InspectionRequest {
  id            String                  @id @default(cuid())
  listingId     String
  listing       Listing                 @relation(fields: [listingId], references: [id])
  sellerId      String
  seller        User                    @relation("InspectionSeller", fields: [sellerId], references: [id])
  workshopPartnerId String?
  workshopPartner   WorkshopPartner?    @relation(fields: [workshopPartnerId], references: [id])
  status        InspectionRequestStatus @default(REQUESTED)
  bookedDate    DateTime?
  offlineFee    Int                     @default(3000)
  workshopPayout Int                    @default(2500)
  tgmgCommission Int                    @default(500)
  offlinePaymentAcknowledged Boolean    @default(false)
  workshopVerifiedById String?
  workshopVerifiedBy   User?            @relation("WorkshopVerifier", fields: [workshopVerifiedById], references: [id])
  policeVerifiedById String?
  policeVerifiedBy     User?            @relation("PoliceVerifier", fields: [policeVerifiedById], references: [id])
  adminReviewedById String?
  adminReviewedBy     User?             @relation("AdminReviewer", fields: [adminReviewedById], references: [id])
  submittedAt   DateTime?
  approvedAt    DateTime?
  rejectedAt    DateTime?
  rejectionNote String?
  report        InspectionReport?
  auditLogs     InspectionAuditLog[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([listingId, status])
  @@index([sellerId, status])
  @@index([workshopPartnerId, status])
}

model InspectionReport {
  id                 String              @id @default(cuid())
  inspectionRequestId String             @unique
  inspectionRequest   InspectionRequest  @relation(fields: [inspectionRequestId], references: [id])
  vehicleInfo         Json
  ownerVerification   Json
  avlsVerification    Json
  mechanicalChecklist Json
  bodyChecklist       Json
  interiorChecklist   Json
  tyreChecklist       Json
  evidencePhotos      String[]           @default([])
  formPageFrontUrl    String?
  formPageBackUrl     String?
  overallRating       Int?
  verdict             InspectionVerdict?
  signatures          Json
  stamps              Json
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model InspectionAuditLog {
  id                 String            @id @default(cuid())
  inspectionRequestId String
  inspectionRequest   InspectionRequest @relation(fields: [inspectionRequestId], references: [id])
  actorUserId        String?
  actorUser          User?             @relation(fields: [actorUserId], references: [id])
  actorRole          UserRole?
  action             String
  note               String?
  payload            Json?
  createdAt          DateTime          @default(now())

  @@index([inspectionRequestId, createdAt])
  @@index([actorUserId, createdAt])
}

enum Condition {
  NEW
  USED
}

enum ListingStatus {
  ACTIVE
  PENDING
  INACTIVE
  SOLD
  DELETED
}

enum StoreType {
  ONLINE
  ROAD
}

enum PushPlatform {
  ANDROID
  IOS
}

enum NotificationType {
  CONTACT
  SAVED_UPDATE
  NEW_LISTING
}

enum UserRole {
  USER
  ADMIN
  WORKSHOP_MANAGER
  POLICE_OFFICER
}

enum ListingInspectionStatus {
  NONE
  REQUESTED
  BOOKED
  WORKSHOP_VERIFIED
  POLICE_VERIFIED
  SUBMITTED
  APPROVED
  REJECTED
  EXPIRED
}

enum InspectionRequestStatus {
  REQUESTED
  BOOKED
  WORKSHOP_VERIFIED
  POLICE_VERIFIED
  SUBMITTED
  APPROVED
  REJECTED
  EXPIRED
}

enum InspectionVerdict {
  RECOMMENDED
  CAUTION
  NOT_RECOMMENDED
}
