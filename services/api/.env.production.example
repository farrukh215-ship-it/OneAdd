NODE_ENV=production
PORT=3001
CORS_ORIGIN=https://teragharmeraghar.com,https://www.teragharmeraghar.com
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/aikad_marketplace?schema=public

JWT_ACCESS_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_ACCESS_EXPIRES_IN=7d
OTP_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
OTP_EXPIRES_MINUTES=3
OTP_MAX_ATTEMPTS=5
OTP_MAX_REQUESTS_PER_WINDOW=3
OTP_REQUEST_WINDOW_MINUTES=3

SMS_PROVIDER=noop
SMS4CONNECT_BASE_URL=https://api.sms4connect.com
SMS4CONNECT_API_KEY=
SMS4CONNECT_SENDER_ID=

PUSH_PROVIDER=fcm
FIREBASE_SERVICE_ACCOUNT_PATH=/app/keys/firebase-admin.json
FIREBASE_WEB_API_KEY=
FCM_PROJECT_ID=aikad-13dc4
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

REDIS_URL=redis://redis:6379
ADMIN_EMAILS=admin@teragharmeraghar.com
AUTO_HIDE_REPORTS_THRESHOLD=5
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60
MEDIA_SIGNING_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
MEDIA_SIGNING_EXPIRES_SECONDS=600
MEDIA_PUBLIC_BASE_URL=https://www.teragharmeraghar.com
