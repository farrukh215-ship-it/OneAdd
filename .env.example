# Database
POSTGRES_DB=tgmg
POSTGRES_USER=tgmg_user
POSTGRES_PASSWORD=your_strong_password

# Redis
REDIS_PASSWORD=your_redis_password

# Auth
JWT_SECRET=your_jwt_secret_minimum_32_chars
NODE_ENV=production
ENABLE_DEV_OTP=false

# Firebase (base64 encoded service account JSON)
FIREBASE_SERVICE_ACCOUNT_JSON=

# SMS Provider: firebase or twilio
SMS_PROVIDER=firebase
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Cloudflare R2 (signed uploads)
CLOUDFLARE_R2_BUCKET=tgmg-media
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.teragharmeraghar.com
